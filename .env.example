# =============================================================================
# APP SETTINGS
# =============================================================================
PROJECT_NAME="AI Girlfriend Chat"
API_PORT=8000
STREAMLIT_PORT=8501
# Keep false on Windows — reload=True leaves orphan processes after Ctrl+C
API_RELOAD=false

# =============================================================================
# LLM PROVIDER
# "local" = best quality (uncensored Gemma, natural Banglish, NSFW) — needs GPU
# "groq"  = free cloud fallback — faster setup, but weaker/censored vs local Gemma
# =============================================================================
LLM_PROVIDER="local"

# =============================================================================
# LOCAL MODEL (Ollama) — used when LLM_PROVIDER=local
# =============================================================================
OLLAMA_MODEL="hf.co/HauhauCS/Gemma4-26B-A4B-Uncensored-HauhauCS-Balanced:Q4_K_M"
OLLAMA_BASE_URL="http://localhost:11434"
# Unload model from GPU/RAM when app exits (Ctrl+C)
OLLAMA_UNLOAD_ON_EXIT=true

# =============================================================================
# GROQ (Cloud) — used when LLM_PROVIDER=groq
# Free API key: https://console.groq.com/keys
# qwen/qwen3-32b: best Groq model for Banglish/Hinglish + natural chat
# llama-3.3-70b-versatile: good English chat, weak on Bengali/Hindi mixing
# =============================================================================
GROQ_API_KEY=""
GROQ_MODEL="qwen/qwen3-32b"

# =============================================================================
# GIRLFRIEND PERSONA
# =============================================================================
GF_NAME="Sneha"
GF_AGE=21
GF_PROFESSION="College Student"

# =============================================================================
# SCHEDULE & TIMEZONE
# Times use 24-hour HH:MM format. Sleep can span midnight (e.g. 23:00 → 07:00)
# =============================================================================
APP_TIMEZONE="Asia/Kolkata"
WORK_START="09:00"
WORK_END="17:00"
SLEEP_START="23:00"
SLEEP_END="07:00"
